{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/edelwud/terraci/raw/main/terraci.schema.json",
  "properties": {
    "service_dir": {
      "type": "string",
      "description": "Service directory for cache and artifacts",
      "default": ".terraci"
    },
    "execution": {
      "properties": {
        "binary": {
          "type": "string",
          "enum": [
            "terraform",
            "tofu"
          ],
          "description": "Terraform/OpenTofu binary to use",
          "default": "terraform"
        },
        "init_enabled": {
          "type": "boolean",
          "description": "Automatically run terraform init before terraform operations",
          "default": true
        },
        "plan_enabled": {
          "type": "boolean",
          "description": "Enable terraform plan jobs",
          "default": true
        },
        "plan_mode": {
          "type": "string",
          "enum": [
            "standard",
            "detailed"
          ],
          "description": "Controls plan artifact verbosity. standard writes only plan.tfplan; detailed also writes plan.txt and plan.json for summary",
          "default": "standard"
        },
        "parallelism": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum parallel jobs for local execution",
          "default": 4
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object",
          "description": "Execution-wide environment variables"
        }
      },
      "type": "object",
      "description": "Shared execution settings for Terraform/OpenTofu"
    },
    "structure": {
      "properties": {
        "pattern": {
          "type": "string",
          "description": "Pattern describing module directory layout. Supported placeholders: {service}, {environment}, {region}, {module}",
          "default": "{service}/{environment}/{region}/{module}"
        }
      },
      "type": "object",
      "description": "Directory structure configuration"
    },
    "exclude": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "description": "Glob patterns for modules to exclude"
    },
    "include": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "description": "Glob patterns for modules to include (if empty"
    },
    "library_modules": {
      "properties": {
        "paths": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "List of directories containing library modules (relative to root)"
        }
      },
      "type": "object",
      "description": "Configuration for library/shared modules (non-executable modules used by other modules)"
    },
    "plugins": {
      "properties": {
        "summary": {
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "on_changes_only": {
              "type": "boolean"
            },
            "include_details": {
              "type": "boolean"
            },
            "labels": {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "cost": {
          "properties": {
            "cache_dir": {
              "type": "string",
              "description": "Deprecated and unsupported; use plugins.diskblob.root_dir instead"
            },
            "blob_cache": {
              "properties": {
                "backend": {
                  "type": "string",
                  "description": "Blob cache backend plugin name",
                  "default": "diskblob"
                },
                "namespace": {
                  "type": "string",
                  "description": "Blob cache namespace for pricing data",
                  "default": "cost/pricing"
                },
                "ttl": {
                  "type": "string",
                  "description": "How long cached pricing is valid (e.g. 24h)",
                  "default": "24h"
                }
              },
              "type": "object",
              "description": "Blob cache backend selection for pricing data"
            },
            "providers": {
              "additionalProperties": {
                "properties": {
                  "enabled": {
                    "type": "boolean",
                    "description": "Enable this cloud provider",
                    "default": false
                  }
                },
                "type": "object"
              },
              "type": "object"
            }
          },
          "type": "object"
        },
        "tfupdate": {
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable terraform dependency resolution",
              "default": false
            },
            "target": {
              "type": "string",
              "enum": [
                "modules",
                "providers",
                "all"
              ],
              "description": "What to inspect: modules providers or all",
              "default": "all"
            },
            "ignore": {
              "items": {
                "type": "string"
              },
              "type": "array",
              "description": "Provider or module sources to ignore"
            },
            "pipeline": {
              "type": "boolean",
              "description": "Add tfupdate check job to CI pipeline",
              "default": false
            },
            "timeout": {
              "type": "string",
              "description": "Overall timeout for a tfupdate run (e.g. 15m)"
            },
            "policy": {
              "properties": {
                "bump": {
                  "type": "string",
                  "enum": [
                    "patch",
                    "minor",
                    "major"
                  ],
                  "description": "Version bump level: patch minor or major"
                },
                "pin": {
                  "type": "boolean",
                  "description": "Pin applied dependency constraints to an exact version",
                  "default": false
                }
              },
              "type": "object"
            },
            "registries": {
              "properties": {
                "default": {
                  "type": "string",
                  "description": "Default registry hostname for modules/providers without lock-based host information",
                  "default": "registry.terraform.io"
                },
                "providers": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "description": "Registry hostname overrides keyed by normalized short provider source"
                }
              },
              "type": "object"
            },
            "lock": {
              "properties": {
                "platforms": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array",
                  "description": "Required platform set for provider h1 hashes"
                }
              },
              "type": "object"
            },
            "cache": {
              "properties": {
                "backend": {
                  "type": "string",
                  "description": "Legacy metadata cache backend plugin name"
                },
                "ttl": {
                  "type": "string",
                  "description": "Legacy metadata cache ttl"
                },
                "namespace": {
                  "type": "string",
                  "description": "Legacy metadata cache namespace"
                },
                "metadata": {
                  "properties": {
                    "backend": {
                      "type": "string",
                      "description": "KV cache backend plugin name",
                      "default": "inmemcache"
                    },
                    "ttl": {
                      "type": "string",
                      "description": "How long registry metadata stays cached",
                      "default": "6h"
                    },
                    "namespace": {
                      "type": "string",
                      "description": "Namespace for tfupdate registry metadata cache",
                      "default": "tfupdate/registry"
                    }
                  },
                  "type": "object"
                },
                "artifacts": {
                  "properties": {
                    "backend": {
                      "type": "string",
                      "description": "Blob store backend plugin name",
                      "default": "diskblob"
                    },
                    "namespace": {
                      "type": "string",
                      "description": "Namespace for cached provider archives and hashes",
                      "default": "tfupdate/providers"
                    }
                  },
                  "type": "object"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        },
        "github": {
          "properties": {
            "runs_on": {
              "type": "string",
              "description": "GitHub Actions runner label (e.g. ubuntu-latest)",
              "default": "ubuntu-latest"
            },
            "container": {
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Docker image name"
                },
                "entrypoint": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array",
                  "description": "Override default entrypoint"
                }
              },
              "type": "object",
              "description": "Container image to run jobs in (optional)"
            },
            "env": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object",
              "description": "Workflow-level environment variables"
            },
            "plan_only": {
              "type": "boolean",
              "description": "Generate only plan jobs (no apply jobs)",
              "default": false
            },
            "auto_approve": {
              "type": "boolean",
              "description": "Auto-approve applies (skip environment protection)",
              "default": false
            },
            "permissions": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object",
              "description": "Workflow-level permissions (e.g. id-token: write for OIDC)"
            },
            "job_defaults": {
              "properties": {
                "runs_on": {
                  "type": "string",
                  "description": "Override runner label"
                },
                "container": {
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Docker image name"
                    },
                    "entrypoint": {
                      "items": {
                        "type": "string"
                      },
                      "type": "array",
                      "description": "Override default entrypoint"
                    }
                  },
                  "type": "object",
                  "description": "Container image for all jobs"
                },
                "env": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "description": "Additional environment variables"
                },
                "steps_before": {
                  "items": {
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "Step display name"
                      },
                      "uses": {
                        "type": "string",
                        "description": "GitHub Action reference"
                      },
                      "with": {
                        "additionalProperties": {
                          "type": "string"
                        },
                        "type": "object",
                        "description": "Action inputs"
                      },
                      "run": {
                        "type": "string",
                        "description": "Shell command to run"
                      },
                      "env": {
                        "additionalProperties": {
                          "type": "string"
                        },
                        "type": "object",
                        "description": "Step environment variables"
                      }
                    },
                    "type": "object"
                  },
                  "type": "array",
                  "description": "Extra steps before terraform commands"
                },
                "steps_after": {
                  "items": {
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "Step display name"
                      },
                      "uses": {
                        "type": "string",
                        "description": "GitHub Action reference"
                      },
                      "with": {
                        "additionalProperties": {
                          "type": "string"
                        },
                        "type": "object",
                        "description": "Action inputs"
                      },
                      "run": {
                        "type": "string",
                        "description": "Shell command to run"
                      },
                      "env": {
                        "additionalProperties": {
                          "type": "string"
                        },
                        "type": "object",
                        "description": "Step environment variables"
                      }
                    },
                    "type": "object"
                  },
                  "type": "array",
                  "description": "Extra steps after terraform commands"
                }
              },
              "type": "object",
              "description": "Default settings applied to all jobs"
            },
            "overwrites": {
              "items": {
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Type of jobs to override (plan, apply, or contributed job name)"
                  },
                  "runs_on": {
                    "type": "string",
                    "description": "Override runner label"
                  },
                  "container": {
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "Docker image name"
                      },
                      "entrypoint": {
                        "items": {
                          "type": "string"
                        },
                        "type": "array",
                        "description": "Override default entrypoint"
                      }
                    },
                    "type": "object",
                    "description": "Container image override"
                  },
                  "env": {
                    "additionalProperties": {
                      "type": "string"
                    },
                    "type": "object",
                    "description": "Additional environment variables"
                  },
                  "steps_before": {
                    "items": {
                      "properties": {
                        "name": {
                          "type": "string",
                          "description": "Step display name"
                        },
                        "uses": {
                          "type": "string",
                          "description": "GitHub Action reference"
                        },
                        "with": {
                          "additionalProperties": {
                            "type": "string"
                          },
                          "type": "object",
                          "description": "Action inputs"
                        },
                        "run": {
                          "type": "string",
                          "description": "Shell command to run"
                        },
                        "env": {
                          "additionalProperties": {
                            "type": "string"
                          },
                          "type": "object",
                          "description": "Step environment variables"
                        }
                      },
                      "type": "object"
                    },
                    "type": "array",
                    "description": "Extra steps before terraform commands"
                  },
                  "steps_after": {
                    "items": {
                      "properties": {
                        "name": {
                          "type": "string",
                          "description": "Step display name"
                        },
                        "uses": {
                          "type": "string",
                          "description": "GitHub Action reference"
                        },
                        "with": {
                          "additionalProperties": {
                            "type": "string"
                          },
                          "type": "object",
                          "description": "Action inputs"
                        },
                        "run": {
                          "type": "string",
                          "description": "Shell command to run"
                        },
                        "env": {
                          "additionalProperties": {
                            "type": "string"
                          },
                          "type": "object",
                          "description": "Step environment variables"
                        }
                      },
                      "type": "object"
                    },
                    "type": "array",
                    "description": "Extra steps after terraform commands"
                  }
                },
                "type": "object",
                "required": [
                  "type"
                ]
              },
              "type": "array",
              "description": "Job-level overrides for plan or apply jobs"
            },
            "pr": {
              "properties": {
                "comment": {
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Enable MR comments",
                      "default": true
                    },
                    "on_changes_only": {
                      "type": "boolean",
                      "description": "Only comment when there are changes"
                    },
                    "include_details": {
                      "type": "boolean",
                      "description": "Include full plan output in expandable sections",
                      "default": true
                    }
                  },
                  "type": "object",
                  "description": "PR comment configuration"
                },
                "summary_job": {
                  "properties": {
                    "runs_on": {
                      "type": "string",
                      "description": "Runner label for summary job"
                    }
                  },
                  "type": "object",
                  "description": "Summary job configuration"
                }
              },
              "type": "object",
              "description": "Pull request integration settings"
            }
          },
          "type": "object"
        },
        "gitlab": {
          "properties": {
            "image": {
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Docker image name"
                },
                "entrypoint": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array",
                  "description": "Override default entrypoint"
                }
              },
              "type": "object",
              "description": "Docker image for terraform jobs"
            },
            "stages_prefix": {
              "type": "string",
              "description": "Prefix for stage names (produces: {prefix}-plan-0, {prefix}-apply-0, etc.)",
              "default": "deploy"
            },
            "parallelism": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum parallel jobs per stage",
              "default": 5
            },
            "variables": {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object",
              "description": "Global pipeline variables"
            },
            "plan_only": {
              "type": "boolean",
              "description": "Generate only plan jobs (no apply jobs)",
              "default": false
            },
            "auto_approve": {
              "type": "boolean",
              "description": "Auto-approve applies (skip manual confirmation)",
              "default": false
            },
            "cache_enabled": {
              "type": "boolean",
              "description": "Enable caching of .terraform directory",
              "default": true
            },
            "cache": {
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Enable GitLab cache for terraform jobs"
                },
                "key": {
                  "type": "string",
                  "description": "Cache key template. Supports placeholders: {module_path}, {service}, {environment}, {region}, {module}"
                },
                "paths": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array",
                  "description": "Cache path templates. Supports placeholders: {module_path}, {service}, {environment}, {region}, {module}"
                },
                "policy": {
                  "type": "string",
                  "enum": [
                    "pull",
                    "push",
                    "pull-push"
                  ],
                  "description": "GitLab cache policy"
                }
              },
              "type": "object",
              "description": "Advanced GitLab cache configuration for terraform jobs"
            },
            "rules": {
              "items": {
                "properties": {
                  "if": {
                    "type": "string"
                  },
                  "when": {
                    "type": "string"
                  },
                  "changes": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  }
                },
                "type": "object"
              },
              "type": "array",
              "description": "Workflow rules for conditional pipeline execution"
            },
            "job_defaults": {
              "properties": {
                "image": {
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Docker image name"
                    },
                    "entrypoint": {
                      "items": {
                        "type": "string"
                      },
                      "type": "array",
                      "description": "Override default entrypoint"
                    }
                  },
                  "type": "object",
                  "description": "Docker image override for all jobs"
                },
                "id_tokens": {
                  "additionalProperties": {
                    "properties": {
                      "aud": {
                        "type": "string"
                      }
                    },
                    "type": "object"
                  },
                  "type": "object",
                  "description": "OIDC tokens for cloud provider authentication"
                },
                "secrets": {
                  "additionalProperties": {
                    "properties": {
                      "vault": {
                        "properties": {
                          "engine": {
                            "properties": {
                              "name": {
                                "type": "string"
                              },
                              "path": {
                                "type": "string"
                              }
                            },
                            "type": "object",
                            "description": "Vault secrets engine configuration"
                          },
                          "path": {
                            "type": "string",
                            "description": "Path to the secret in Vault"
                          },
                          "field": {
                            "type": "string",
                            "description": "Field to extract from the secret"
                          }
                        },
                        "type": "object",
                        "description": "HashiCorp Vault secret configuration"
                      },
                      "file": {
                        "type": "boolean",
                        "description": "Write secret to a file"
                      }
                    },
                    "type": "object"
                  },
                  "type": "object",
                  "description": "Secrets from external secret managers"
                },
                "before_script": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array",
                  "description": "Commands to run before each job"
                },
                "after_script": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array",
                  "description": "Commands to run after each job"
                },
                "artifacts": {
                  "properties": {
                    "paths": {
                      "items": {
                        "type": "string"
                      },
                      "type": "array",
                      "description": "File/directory paths to include as artifacts"
                    },
                    "expire_in": {
                      "type": "string",
                      "description": "How long to keep artifacts (e.g. '1 day', '1 week')"
                    },
                    "reports": {
                      "properties": {
                        "terraform": {
                          "items": {
                            "type": "string"
                          },
                          "type": "array",
                          "description": "Terraform report paths"
                        },
                        "junit": {
                          "items": {
                            "type": "string"
                          },
                          "type": "array",
                          "description": "JUnit report paths"
                        },
                        "cobertura": {
                          "items": {
                            "type": "string"
                          },
                          "type": "array",
                          "description": "Cobertura coverage report paths"
                        }
                      },
                      "type": "object",
                      "description": "Artifact reports configuration"
                    },
                    "name": {
                      "type": "string",
                      "description": "Artifact archive name"
                    },
                    "untracked": {
                      "type": "boolean",
                      "description": "Include all untracked files"
                    },
                    "when": {
                      "type": "string",
                      "enum": [
                        "on_success",
                        "on_failure",
                        "always"
                      ],
                      "description": "When to upload artifacts"
                    },
                    "expose_as": {
                      "type": "string",
                      "description": "Makes artifacts available in MR UI"
                    }
                  },
                  "type": "object",
                  "description": "GitLab CI artifacts configuration"
                },
                "tags": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array",
                  "description": "GitLab runner tags"
                },
                "rules": {
                  "items": {
                    "properties": {
                      "if": {
                        "type": "string"
                      },
                      "when": {
                        "type": "string"
                      },
                      "changes": {
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      }
                    },
                    "type": "object"
                  },
                  "type": "array",
                  "description": "Job-level rules"
                },
                "variables": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "description": "Additional variables"
                }
              },
              "type": "object",
              "description": "Default settings applied to all jobs"
            },
            "overwrites": {
              "items": {
                "properties": {
                  "type": {
                    "type": "string",
                    "description": "Type of jobs to override (plan, apply, or contributed job name)"
                  },
                  "image": {
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "Docker image name"
                      },
                      "entrypoint": {
                        "items": {
                          "type": "string"
                        },
                        "type": "array",
                        "description": "Override default entrypoint"
                      }
                    },
                    "type": "object",
                    "description": "Docker image override for matching jobs"
                  },
                  "id_tokens": {
                    "additionalProperties": {
                      "properties": {
                        "aud": {
                          "type": "string"
                        }
                      },
                      "type": "object"
                    },
                    "type": "object",
                    "description": "OIDC tokens for matching jobs"
                  },
                  "secrets": {
                    "additionalProperties": {
                      "properties": {
                        "vault": {
                          "properties": {
                            "engine": {
                              "properties": {
                                "name": {
                                  "type": "string"
                                },
                                "path": {
                                  "type": "string"
                                }
                              },
                              "type": "object",
                              "description": "Vault secrets engine configuration"
                            },
                            "path": {
                              "type": "string",
                              "description": "Path to the secret in Vault"
                            },
                            "field": {
                              "type": "string",
                              "description": "Field to extract from the secret"
                            }
                          },
                          "type": "object",
                          "description": "HashiCorp Vault secret configuration"
                        },
                        "file": {
                          "type": "boolean",
                          "description": "Write secret to a file"
                        }
                      },
                      "type": "object"
                    },
                    "type": "object",
                    "description": "Secrets for matching jobs"
                  },
                  "before_script": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array",
                    "description": "Commands to run before matching jobs"
                  },
                  "after_script": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array",
                    "description": "Commands to run after matching jobs"
                  },
                  "artifacts": {
                    "properties": {
                      "paths": {
                        "items": {
                          "type": "string"
                        },
                        "type": "array",
                        "description": "File/directory paths to include as artifacts"
                      },
                      "expire_in": {
                        "type": "string",
                        "description": "How long to keep artifacts (e.g. '1 day', '1 week')"
                      },
                      "reports": {
                        "properties": {
                          "terraform": {
                            "items": {
                              "type": "string"
                            },
                            "type": "array",
                            "description": "Terraform report paths"
                          },
